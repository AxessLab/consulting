<!DOCTYPE html>
<html lang="{{ 'sv' if language == 'swedish' else 'en' }}">
<head>
  <meta charset="utf-8" />
  <title>{{ consultant_name }} — CV</title>
  <style>
    @page { size: A4; margin: 16mm 14mm; }
    * { box-sizing: border-box; }
    body {
      font-family: "Segoe UI", Calibri, Arial, sans-serif;
      font-size: 10.5pt;
      line-height: 1.45;
      color: #1a1a1a;
      margin: 0;
      padding: 0;
    }
    .page {
      max-width: 182mm;
      margin: 0 auto;
      padding: 10mm 0 14mm;
    }
    .cv-header {
      display: flex;
      align-items: flex-start;
      justify-content: space-between;
      gap: 6mm;
      margin-bottom: 5mm;
    }
    .cv-header-left { flex: 1 1 auto; min-width: 0; }
    .logo {
      display: block;
      max-width: 72mm;
      height: auto;
      margin-bottom: 3mm;
    }
    .portrait {
      flex: 0 0 auto;
      width: 28mm;
      height: 28mm;
      object-fit: cover;
      border-radius: 2px;
      border: 1px solid #d8dee4;
    }
    .contact {
      font-size: 9.5pt;
      color: #444;
      margin-bottom: 4mm;
    }
    .contact-label {
      font-weight: 600;
      color: #333;
    }
    h1 {
      font-size: 21pt;
      font-weight: 600;
      margin: 0 0 2mm;
      letter-spacing: -0.02em;
    }
    .role {
      font-size: 12pt;
      color: #333;
      margin: 0 0 4mm;
    }
    h2 {
      font-size: 11pt;
      text-transform: uppercase;
      letter-spacing: 0.06em;
      color: #2d6a9f;
      border-bottom: 1px solid #d8dee4;
      padding-bottom: 1.5mm;
      margin: 6mm 0 3mm;
    }
    p { margin: 0 0 3mm; }
    .chips { display: flex; flex-wrap: wrap; gap: 2mm; margin: 2mm 0 4mm; }
    .chip {
      background: #eef2f6;
      border: 1px solid #d0d9e2;
      border-radius: 3px;
      padding: 1mm 2.5mm;
      font-size: 9pt;
    }
    .project { margin-bottom: 4mm; page-break-inside: avoid; }
    .project-meta {
      font-weight: 600;
      font-size: 10pt;
      margin-bottom: 1mm;
    }
    .project-sub { font-size: 9.5pt; color: #555; margin-bottom: 1.5mm; }
    .skills-grid { columns: 2; column-gap: 6mm; font-size: 9.5pt; }
    .skills-grid p { break-inside: avoid; margin-bottom: 2mm; }
    .lang-list { margin: 0; }
    @media print {
      .page { padding: 0; }
    }
  </style>
</head>
<body>
  <div class="page">
    <header class="cv-header">
      <div class="cv-header-left">
        {% if logo_data_uri %}
        <img class="logo" src="{{ logo_data_uri }}" alt="Axesslab" />
        {% endif %}
        <div class="contact"><span class="contact-label">{{ labels.contact }}:</span> {{ contact.name }} · {{ contact.email }} · {{ contact.phone }}</div>
        <h1>{{ consultant_name }}</h1>
        <p class="role">{{ role_title }}</p>
      </div>
      {% if portrait_data_uri %}
      <img class="portrait" src="{{ portrait_data_uri }}" alt="{{ consultant_name }}" />
      {% endif %}
    </header>

    {% for paragraph in profile_paragraphs %}
    <p>{{ paragraph }}</p>
    {% endfor %}

    <h2>{{ labels.selected_evidence }}</h2>
    {% for item in selected_evidence %}
    <div class="project">
      <div class="project-meta">{{ item.title }}</div>
      {% if item.subtitle %}<div class="project-sub">{{ item.subtitle }}</div>{% endif %}
      <p>{{ item.summary }}</p>
    </div>
    {% endfor %}

    <h2>{{ labels.relevant_competence }}</h2>
    <div class="chips">
      {% for chip in competence_chips %}
      <span class="chip">{{ chip }}</span>
      {% endfor %}
    </div>

    <h2>{{ labels.projects }}</h2>
    {% for item in projects %}
    <div class="project">
      <div class="project-meta">{{ item.title }}</div>
      {% if item.subtitle %}<div class="project-sub">{{ item.subtitle }}</div>{% endif %}
      <p>{{ item.summary }}</p>
      {% if item.skills %}
      <div class="chips">
        {% for skill in item.skills %}
        <span class="chip">{{ skill }}</span>
        {% endfor %}
      </div>
      {% endif %}
    </div>
    {% endfor %}

    <h2>{{ labels.skills }}</h2>
    <div class="skills-grid">
      {% for row in skill_levels %}
      <p><strong>{{ row.level }}:</strong> {{ row.skills }}</p>
      {% endfor %}
    </div>

    {% if certifications %}
    <h2>{{ labels.certifications }}</h2>
    <p>{{ certifications }}</p>
    {% endif %}

    <h2>{{ labels.languages }}</h2>
    <p class="lang-list">
      {% for lang in languages %}
      {{- lang.language }} — {{ lang.proficiency }}{% if not loop.last %} · {% endif %}
      {% endfor %}
    </p>
  </div>
</body>
</html>
