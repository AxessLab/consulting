{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/AxessLab/consulting/schemas/consultants.schema.json",
  "title": "Consultant metadata",
  "description": "Schema for consultants.yaml, the source of truth for consultant lookup metadata used by Cursor Automations.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "companyId",
    "consultants"
  ],
  "properties": {
    "companyId": {
      "description": "Cinode company id. Use a placeholder value until configured in automation secrets/env vars.",
      "type": "integer",
      "minimum": 0
    },
    "consultants": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "canonicalName",
          "aliases",
          "cinodeCompanyUserId",
          "mainRoles",
          "locations",
          "cvs",
          "active"
        ],
        "properties": {
          "canonicalName": {
            "type": "string",
            "minLength": 1
          },
          "aliases": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            },
            "uniqueItems": true
          },
          "cinodeCompanyUserId": {
            "description": "Cinode company user id used in the CompanyUserProfile endpoint.",
            "type": "integer",
            "minimum": 0
          },
          "slug": {
            "description": "Optional URL-safe identifier used in generated CV filenames, e.g. karin-toft. Derived from canonicalName when omitted.",
            "type": "string",
            "pattern": "^[a-z0-9-]+$"
          },
          "photoFile": {
            "description": "Optional path to a portrait image for HTML/PDF rendering, e.g. photos/karin-toft.png.",
            "type": "string",
            "pattern": "^photos/.+"
          },
          "mainRoles": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            },
            "uniqueItems": true
          },
          "locations": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            },
            "uniqueItems": true
          },
          "cvs": {
            "description": "Curated CV variants for this consultant. Automations pick the best-matching active variant per assignment.",
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "id",
                "label",
                "summaryFile",
                "roles",
                "active"
              ],
              "properties": {
                "id": {
                  "description": "Stable machine-readable identifier for this CV variant.",
                  "type": "string",
                  "pattern": "^[a-z0-9-]+$"
                },
                "label": {
                  "description": "Human-readable label shown in Slack replies.",
                  "type": "string",
                  "minLength": 1
                },
                "summaryFile": {
                  "description": "Path to the curated Markdown summary for this variant.",
                  "type": "string",
                  "pattern": "^cv-summaries/.+\\.md$"
                },
                "rawFiles": {
                  "description": "Optional paths to source CV documents under cvs/.",
                  "type": "array",
                  "items": {
                    "type": "string",
                    "pattern": "^cvs/.+"
                  },
                  "uniqueItems": true
                },
                "roles": {
                  "description": "Role and skill tags used to match this variant against assignments.",
                  "type": "array",
                  "minItems": 1,
                  "items": {
                    "type": "string",
                    "minLength": 1
                  },
                  "uniqueItems": true
                },
                "emphasis": {
                  "description": "Short note on what this variant leads with for assignment matching.",
                  "type": "string",
                  "minLength": 1
                },
                "active": {
                  "type": "boolean"
                }
              }
            }
          },
          "active": {
            "type": "boolean"
          }
        }
      }
    }
  }
}
