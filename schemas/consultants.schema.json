{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/AxessLab/consulting/schemas/consultants.schema.json",
  "title": "Consultant metadata",
  "description": "Schema for consultants.yaml, the source of truth for consultant lookup metadata used by Cursor Automations.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "companyId",
    "consultants"
  ],
  "properties": {
    "companyId": {
      "description": "Cinode company id. Use a placeholder value until configured in automation secrets/env vars.",
      "type": "integer",
      "minimum": 0
    },
    "consultants": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "canonicalName",
          "aliases",
          "cinodeCompanyUserId",
          "mainRoles",
          "locations",
          "cvSummaryFile",
          "sourceCvFiles",
          "active"
        ],
        "properties": {
          "canonicalName": {
            "type": "string",
            "minLength": 1
          },
          "aliases": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            },
            "uniqueItems": true
          },
          "cinodeCompanyUserId": {
            "description": "Cinode company user id used in the CompanyUserProfile endpoint.",
            "type": "integer",
            "minimum": 0
          },
          "mainRoles": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            },
            "uniqueItems": true
          },
          "locations": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            },
            "uniqueItems": true
          },
          "cvSummaryFile": {
            "type": "string",
            "pattern": "^cv-summaries/.+\\.md$"
          },
          "sourceCvFiles": {
            "description": "Existing source CV files available for assignment-specific DOCX generation.",
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "path",
                "language",
                "role",
                "default"
              ],
              "properties": {
                "path": {
                  "description": "Path to the source CV in this repository.",
                  "type": "string",
                  "pattern": "^cvs/.+\\.(pdf|PDF|docx|DOCX)$"
                },
                "language": {
                  "description": "Language of the source CV.",
                  "type": "string",
                  "enum": [
                    "english",
                    "swedish"
                  ]
                },
                "role": {
                  "description": "Role variant inferred from the source CV filename, ignoring client names.",
                  "type": "string",
                  "minLength": 1
                },
                "default": {
                  "description": "Whether this is the default source CV when no better role or language match is found.",
                  "type": "boolean"
                }
              }
            },
            "uniqueItems": true
          },
          "active": {
            "type": "boolean"
          }
        }
      }
    }
  }
}
