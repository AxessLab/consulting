{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/AxessLab/consulting/schemas/cv-content.schema.json",
  "title": "Assignment-specific CV content",
  "description": "Structured content for scripts/render-cv.py. The generate automation produces this JSON; the render script produces HTML and PDF.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "consultantSlug",
    "language",
    "assignmentId",
    "assignmentTitle",
    "variantId",
    "contact",
    "consultantName",
    "roleTitle",
    "profileParagraphs",
    "selectedEvidence",
    "competenceChips",
    "projects",
    "skillLevels",
    "languages"
  ],
  "properties": {
    "consultantSlug": {
      "type": "string",
      "pattern": "^[a-z0-9-]+$",
      "description": "URL-safe consultant identifier, e.g. karin-toft."
    },
    "language": {
      "type": "string",
      "enum": ["english", "swedish"],
      "description": "Output language. For english, apply automation-prompts/translation-sv-en.md (tillgänglighet -> accessibility, not availability)."
    },
    "assignmentId": {
      "type": "string",
      "minLength": 1,
      "description": "Platform assignment id from the listing, or manual for pasted ad text in Slack."
    },
    "assignmentTitle": {
      "type": "string",
      "minLength": 1,
      "description": "Assignment name for Slack replies, JSON metadata, and the generated-cvs folder label. Not rendered in the client-facing CV."
    },
    "assignmentFolder": {
      "type": "string",
      "minLength": 1,
      "description": "Optional override for the generated-cvs subdirectory name. Defaults to `<assignmentId> - <sanitized assignmentTitle>`."
    },
    "variantId": {
      "type": "string",
      "pattern": "^[a-z0-9-]+$"
    },
    "variantLabel": {
      "type": "string",
      "description": "Human-readable CV variant label for Slack replies."
    },
    "sourceCv": {
      "type": "string",
      "description": "Path to the source CV used for facts, e.g. cvs/example.docx."
    },
    "contact": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "email", "phone"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "email": { "type": "string", "minLength": 1 },
        "phone": { "type": "string", "minLength": 1 }
      }
    },
    "consultantName": {
      "type": "string",
      "minLength": 1
    },
    "roleTitle": {
      "type": "string",
      "minLength": 1
    },
    "profileParagraphs": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "selectedEvidence": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/projectBlock" }
    },
    "competenceChips": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "projects": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/projectBlock" }
    },
    "skillLevels": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["level", "skills"],
        "properties": {
          "level": { "type": "string", "minLength": 1 },
          "skills": { "type": "string", "minLength": 1 }
        }
      }
    },
    "certifications": {
      "type": "string"
    },
    "languages": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["language", "proficiency"],
        "properties": {
          "language": { "type": "string", "minLength": 1 },
          "proficiency": { "type": "string", "minLength": 1 }
        }
      }
    },
    "labels": {
      "type": "object",
      "description": "Optional section headings. Defaults are chosen from language when omitted.",
      "additionalProperties": false,
      "properties": {
        "contact": { "type": "string" },
        "selectedEvidence": { "type": "string" },
        "relevantCompetence": { "type": "string" },
        "projects": { "type": "string" },
        "skills": { "type": "string" },
        "certifications": { "type": "string" },
        "languages": { "type": "string" }
      }
    }
  },
  "$defs": {
    "projectBlock": {
      "type": "object",
      "additionalProperties": false,
      "required": ["title", "summary"],
      "properties": {
        "title": {
          "type": "string",
          "minLength": 1,
          "description": "Role and client, e.g. Frontend developer · Zalando."
        },
        "subtitle": {
          "type": "string",
          "description": "Dates and location."
        },
        "summary": {
          "type": "string",
          "minLength": 1
        },
        "skills": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      }
    }
  }
}
